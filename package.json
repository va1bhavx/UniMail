{
  "name": "UniMail",
  "description": "All your inboxes. One calm place.",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check",
    "format": "biome format --write",
    "prepare": "husky install",
    "typecheck": "tsc --noEmit"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "biome check --write",
      "tsc --noEmit"
    ],
    "*.{json,md}": [
      "biome format --write"
    ]
  },
  "dependencies": {
    "@prisma/client": "^7.7.0",
    "@tanstack/react-query": "^5.99.2",
    "axios": "^1.15.2",
    "bcrypt": "^6.0.0",
    "clsx": "^2.1.1",
    "imapflow": "^1.3.2",
    "lucide-react": "^1.8.0",
    "mailparser": "^3.9.8",
    "next": "16.2.4",
    "next-auth": "^4.24.14",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "pino": "^10.3.1",
    "prisma": "^7.7.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "husky": "^8.0.0",
    "lint-staged": "^16.4.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
